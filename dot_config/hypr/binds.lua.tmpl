-- Rearrange windows in the current workspace
hl.bind(MOD .. " + down", hl.dsp.window.move({ direction = "down" }), {description = "Move window down"})
hl.bind(MOD .. " + left", hl.dsp.window.move({ direction = "left" }), {description = "Move window left"})
hl.bind(MOD .. " + right", hl.dsp.window.move({ direction = "right" }), {description = "Move window right"})
hl.bind(MOD .. " + up", hl.dsp.window.move({ direction = "up" }), {description = "Move window up"})

-- Move Windows Between Workspaces
local hs = require("hyprsplit")
hs.config({ num_workspaces = 9 })
for i = 1, 9 do
    hl.bind("SUPER + " .. i, hs.dsp.focus({ workspace = i }), {description = "Switch to workspace " .. i})
    hl.bind("SUPER + SHIFT + " .. i, hs.dsp.window.move({ workspace = i, follow = true }), {description = "Move window to workspace " .. i})
end

local throttled = false
local function throttled_dsp(dsp)
    return function()
        if throttled then return end
        throttled = true
        hl.dispatch(dsp)
        hl.timer(
            function()
                throttled = false
            end,
            {
                timeout = 200,
                type = "oneshot",
            }
        )
    end
end

local prevWs = hl.dsp.focus({ workspace = "r-1" })
local nextWs = hl.dsp.focus({ workspace = "r+1" })

hl.bind(MOD .. " + mouse_up", throttled_dsp(prevWs), {description = "Switch to previous workspace"})
hl.bind(MOD .. " + mouse_down", throttled_dsp(nextWs), {description = "Switch to next workspace"})

-- Move focus between windows in the current workspace
hl.bind(MOD .. " + S", hl.dsp.focus({ direction = "down" }), {description = "Focus window below"})
hl.bind(MOD .. " + A", hl.dsp.focus({ direction = "left" }), {description = "Focus window to the left"})
hl.bind(MOD .. " + D", hl.dsp.focus({ direction = "right" }), {description = "Focus window to the right"})
hl.bind(MOD .. " + W", hl.dsp.focus({ direction = "up" }), {description = "Focus window above"})

-- Resize windows in the current workspace
local resize_amount = 10
hl.bind(MOD .. " + SHIFT + S", hl.dsp.window.resize({x=resize_amount,y=resize_amount, relative=true}), { repeating = true, description = "Resize window (expand)"})
hl.bind(MOD .. " + SHIFT + A", hl.dsp.window.resize({x=-resize_amount,y=0, relative=true}), { repeating = true, description = "Resize window (shrink left)"})
hl.bind(MOD .. " + SHIFT + D", hl.dsp.window.resize({x=resize_amount,y=0, relative=true}), { repeating = true, description = "Resize window (expand right)"})
hl.bind(MOD .. " + SHIFT + W", hl.dsp.window.resize({x=0,y=-resize_amount, relative=true}), { repeating = true, description = "Resize window (shrink top)"})

-- Move Windows Between Monitors
hl.bind(MOD .. " + SHIFT + left", hl.dsp.window.move({ monitor = "l" }), {description = "Move window to left monitor"})
hl.bind(MOD .. " + SHIFT + right", hl.dsp.window.move({ monitor = "r" }), {description = "Move window to right monitor"})

-- Move Windows with Mouse
hl.bind(MOD .. " + mouse:272", hl.dsp.window.drag(), { mouse = true, description = "Drag window with mouse"})
