-- Rearrange windows in the current workspace
hl.bind(MOD .. " + down", hl.dsp.window.move({ direction = "down" }))
hl.bind(MOD .. " + left", hl.dsp.window.move({ direction = "left" }))
hl.bind(MOD .. " + right", hl.dsp.window.move({ direction = "right" }))
hl.bind(MOD .. " + up", hl.dsp.window.move({ direction = "up" }))

-- Move Windows Between Workspaces
local hs = require("hyprsplit")
hs.config({ num_workspaces = 9 })
for i = 1, 9 do
    hl.bind("SUPER + " .. i, hs.dsp.focus({ workspace = i }))
    hl.bind("SUPER + SHIFT + " .. i, hs.dsp.window.move({ workspace = i, follow = true }))
end

local throttled = false
local function throttled_dsp(dsp)
    return function()
        if throttled then return end
        throttled = true
        hl.dispatch(dsp)
        hl.timer(
            function()
                throttled = false
            end,
            {
                timeout = 200,
                type = "oneshot",
            }
        )
    end
end

local prevWs = hl.dsp.focus({ workspace = "r-1" })
local nextWs = hl.dsp.focus({ workspace = "r+1" })

hl.bind(MOD .. " + mouse_up", throttled_dsp(prevWs))
hl.bind(MOD .. " + mouse_down", throttled_dsp(nextWs))

-- Move focus between windows in the current workspace
hl.bind(MOD .. " + S", hl.dsp.focus({ direction = "down" }))
hl.bind(MOD .. " + A", hl.dsp.focus({ direction = "left" }))
hl.bind(MOD .. " + D", hl.dsp.focus({ direction = "right" }))
hl.bind(MOD .. " + W", hl.dsp.focus({ direction = "up" }))

-- Resize windows in the current workspace
local resize_amount = 10
hl.bind(MOD .. " + SHIFT + S", hl.dsp.window.resize({x=resize_amount,y=resize_amount, relative=true}), { repeating = true })
hl.bind(MOD .. " + SHIFT + A", hl.dsp.window.resize({x=-resize_amount,y=0, relative=true}), { repeating = true })
hl.bind(MOD .. " + SHIFT + D", hl.dsp.window.resize({x=resize_amount,y=0, relative=true}), { repeating = true })
hl.bind(MOD .. " + SHIFT + W", hl.dsp.window.resize({x=0,y=-resize_amount, relative=true}), { repeating = true })

-- Move Windows Between Monitors
hl.bind(MOD .. " + SHIFT + left", hl.dsp.window.move({ monitor = "l" }))
hl.bind(MOD .. " + SHIFT + right", hl.dsp.window.move({ monitor = "r" }))

-- Move Windows with Mouse
hl.bind(MOD .. " + mouse:272", hl.dsp.window.drag(), { mouse = true })

-- Screen lock when the switch is turning off and then suspend
hl.bind("switch:on:Lid Switch", hl.dsp.exec_cmd("{{.utilities.lockscreen.linux.command }} & ;sleep 1; systemctl suspend"), { locked = true })
