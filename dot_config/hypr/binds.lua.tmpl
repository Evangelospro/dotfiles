-- Utilities
hl.bind(MOD .. " + Z", function()
    zoom_factor = hl.get_config("cursor.zoom_factor")
    hl.config({cursor = { zoom_factor = zoom_factor + 0.1 }})
end)
hl.bind(MOD .. " + SHIFT + Z", function()
    zoom_factor = hl.get_config("cursor.zoom_factor")
    if zoom_factor > 1.0 then
        hl.config({cursor = { zoom_factor = zoom_factor - 0.1 }})
    end
end)
