-- Debug configuration
hl.config({
    debug = {
        overlay = false,
        disable_logs = true,
        enable_stdout_logs = true,
        colored_stdout_logs = true,
    },
})

-- Input configuration
hl.config({
    input = {
        numlock_by_default = true,
        resolve_binds_by_sym = 0,
        -- 0 - Cursor movement will not change focus.
        -- 1 - Cursor movement will always change focus to the window under the cursor.
        -- 2 - Cursor focus will be detached from keyboard focus. Clicking on a window will move keyboard focus to that window.
        -- 3 - Cursor focus will be completely separate from keyboard focus. Clicking on a window will not change keyboard focus.
        follow_mouse = 1,
        sensitivity = 0, -- -1.0 - 1.0, 0 means no modification.
        kb_layout = "us,gr",
        kb_options = "grp:alt_shift_toggle",
    },
})

-- General configuration
hl.config({
    general = {
        resize_on_border = true,
        gaps_in = 5,
        gaps_out = 5,
        border_size = 5,
        layout = "dwindle",
        -- gradient with the dracula theme
        col = {
            inactive_border = "rgba(bd93f9ff)",
            active_border = { colors = { "rgba(ff5555ff)", "rgba(ffb86cff)", "rgba(fff1fa8c)", "rgba(50fa7bff)", "rgba(8be9fdff)", "rgba(ff79c6ff)", "rgba(bd93f9ff)" }, angle = 45 },
        },
    },
})

-- Decoration configuration
hl.config({
    decoration = {
        active_opacity = 1.0,
        inactive_opacity = 1.0, -- 0.87
        -- fullscreen_opacity = 1.0
        rounding = 5,
        blur = {
            new_optimizations = true,
            ignore_opacity = true,
            enabled = true,
            size = 10, -- minimum 1
            passes = 2, -- minimum 1, more passes = more resource intensive.
            -- Your blur "amount" is blur_size * blur_passes, but high blur_size (over around 5-ish) will produce artifacts.
            -- if you want heavy blur, you need to up the blur_passes.
            -- the more passes, the more you can up the blur_size without noticing artifacts.
            xray = true, -- no need to blur background windows when there are floating ones in front of them.
        },
    },
})

-- Animations configuration
hl.animation({ leaf = "border", enabled = true, speed = 2, bezier = "default" })
hl.animation({ leaf = "fade", enabled = true, speed = 4, bezier = "default" })
hl.animation({ leaf = "windows", enabled = true, speed = 3, bezier = "default", style = "popin 80%" })
hl.animation({ leaf = "workspaces", enabled = true, speed = 2, bezier = "default", style = "slide" })

-- Dwindle layout configuration
hl.config({
    dwindle = {
        -- keep floating dimentions while tiling
        -- pseudotile = true,
        force_split = 0,
        preserve_split = 1,
    },
})

-- Gesture configuration
hl.gesture({
    fingers = 3,
    direction = "horizontal",
    action = "workspace",
})

-- Binds configuration
hl.config({
    binds = {
        focus_preferred_method = 1, -- find focus by longer shared edges
    },
})

-- Cursor configuration
hl.config({
    cursor = {
        default_monitor = "eDP-2",
        inactive_timeout = 0,
        enable_hyprcursor = true,
        zoom_factor = 1.0,
        zoom_rigid = true,
    },
})

-- Misc configuration
hl.config({
    misc = {
        disable_hyprland_logo = true,
        disable_splash_rendering = true,
        mouse_move_enables_dpms = true,
        key_press_enables_dpms = true,
        -- enable_swallow = true
        -- swallow_regex = "^({{.applications.terminal.linux.class}})$"
        always_follow_on_dnd = true,
        animate_manual_resizes = true,
        layers_hog_keyboard_focus = true,
        focus_on_activate = false,
        mouse_move_focuses_monitor = true,
        allow_session_lock_restore = true,
        vrr = 0,
        -- Make apps open on the workspace they were opened on
        -- e.g by a launcher or terminal (looking at you Discord and Spotify)
        -- initial_workspace_tracking = 2
        middle_click_paste = true,
    },
})

